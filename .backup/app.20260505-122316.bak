    // 搜索功能初始化（首页）
    function initSearchOnHome() {
        var searchForm = document.getElementById('homeSearchForm');
        if (!searchForm) return;

        var countrySelect = document.getElementById('searchCountry');
        var paymentSelect = document.getElementById('searchPayment');
        var deviceSelect = document.getElementById('searchDevice');
        var resultContainer = document.getElementById('searchResults');

        if (!countrySelect || !paymentSelect || !deviceSelect) return;

        // 填充下拉选项
        populateSearchOptions(countrySelect, SEARCH_CONFIG.countries, 'code', 'name');
        populateSearchOptions(paymentSelect, SEARCH_CONFIG.paymentMethods, 'code', 'name');
        populateSearchOptions(deviceSelect, SEARCH_CONFIG.deviceTypes, 'code', 'name');

        if (searchForm.dataset.searchInitialized === 'true') return;
        searchForm.dataset.searchInitialized = 'true';

        // 表单提交事件
        searchForm.addEventListener('submit', function (e) {
            e.preventDefault();
            performSearch(countrySelect.value, paymentSelect.value, deviceSelect.value, resultContainer);
        });

        // 下拉变化时自动搜索
        [countrySelect, paymentSelect, deviceSelect].forEach(function (sel) {
            sel.addEventListener('change', function () {
                if (countrySelect.value !== 'all' || paymentSelect.value !== 'all' || deviceSelect.value !== 'all') {
                    performSearch(countrySelect.value, paymentSelect.value, deviceSelect.value, resultContainer);
                }
            });
        });
    }

    function populateSearchOptions(selectEl, data, keyField, labelField) {
        var isEn = currentLang === 'en';
        selectEl.innerHTML = '';
        data.forEach(function (item) {
            var opt = document.createElement('option');
            opt.value = item[keyField];
            opt.textContent = (item.flag ? item.flag + ' ' : '') + (isEn ? (item.nameEn || item[labelField]) : item[labelField]);
            selectEl.appendChild(opt);
        });
    }

    function performSearch(country, payment, device, resultContainer) {
        if (!resultContainer) return;
        var isEn = currentLang === 'en';

        // 至少选择一个条件
        if (country === 'all' && payment === 'all' && device === 'all') {
            resultContainer.innerHTML = '<div class="search-result-empty"><i class="fas fa-search"></i><p>' + (isEn ? 'Please select at least one search criteria' : '请至少选择一个搜索条件') + '</p></div>';
            resultContainer.style.display = 'block';
            return;
        }

        var results = [];
        var countriesToSearch = country === 'all' ? SEARCH_CONFIG.countries.filter(function (c) { return c.code !== 'all'; }) : SEARCH_CONFIG.countries.filter(function (c) { return c.code === country; });
        var paymentsToSearch = payment === 'all' ? SEARCH_CONFIG.paymentMethods.filter(function (p) { return p.code !== 'all'; }) : SEARCH_CONFIG.paymentMethods.filter(function (p) { return p.code === payment; });
        var devicesToSearch = device === 'all' ? null : SEARCH_CONFIG.deviceTypes.filter(function (d) { return d.code === device; });

        countriesToSearch.forEach(function (countryItem) {
            var matrix = SEARCH_CONFIG.supportMatrix[countryItem.code];
            if (!matrix) return;

            var supportedPayments = [];
            paymentsToSearch.forEach(function (payItem) {
                var payDevices = matrix[payItem.code];
                if (!payDevices) return;

                var matchedDevices = [];
                if (devicesToSearch && devicesToSearch.length > 0) {
                    // 检查指定设备是否在支持列表中
                    devicesToSearch.forEach(function (devItem) {
                        if (payDevices.indexOf(devItem.code) !== -1) {
                            matchedDevices.push(devItem);
                        }
                    });
                } else {
                    // 返回所有支持的设备
                    payDevices.forEach(function (devCode) {
                        var devItem = SEARCH_CONFIG.deviceTypes.find(function (d) { return d.code === devCode; });
                        if (devItem) matchedDevices.push(devItem);
                    });
                }

                if (matchedDevices.length > 0) {
                    supportedPayments.push({
                        payment: payItem,
                        devices: matchedDevices
                    });
                }
            });

            if (supportedPayments.length > 0) {
                results.push({
                    country: countryItem,
                    payments: supportedPayments
                });
            }
        });

        renderSearchResults(results, resultContainer);
    }

    function renderSearchResults(results, container) {
        var isEn = currentLang === 'en';

        if (results.length === 0) {
            container.innerHTML = '<div class="search-result-empty"><i class="fas fa-exclamation-circle"></i><p>' + (isEn ? 'No common supported pack found. Please adjust your criteria or contact sales for a custom configuration.' : '暂未找到常见可支持方案。请调整搜索条件，或联系我们的销售团队获取定制配置。') + '</p><a href="contact.html" class="btn-primary btn-sm">' + (isEn ? 'Contact Sales' : '联系销售') + ' <i class="fas fa-arrow-right"></i></a></div>';
            container.style.display = 'block';
            return;
        }

        var html = '<div class="search-result-header"><h3>' + (isEn ? 'Search Results' : '搜索结果') + '</h3><span class="search-result-count">' + (isEn ? 'Found ' + results.length + ' region(s)' : '找到 ' + results.length + ' 个地区') + '</span></div>';
        html += '<p class="search-result-disclaimer">' + (isEn ? 'These are common support references only. Final device model, currency, certification, and pricing should be confirmed with Totem sales.' : '以下为常见可支持方案参考，最终设备型号、币种、认证与报价请联系 Totem 销售确认。') + '</p>';
        html += '<div class="search-result-grid">';

        results.forEach(function (result) {
            html += '<div class="search-result-card">';
            html += '<div class="search-result-country">';
            html += '<span class="country-flag">' + (result.country.flag || '🌍') + '</span>';
            html += '<h4>' + (isEn ? result.country.nameEn : result.country.name) + '</h4>';
            html += '</div>';
            html += '<div class="search-result-payments">';

            result.payments.forEach(function (payInfo) {
                html += '<div class="payment-group">';
                html += '<div class="payment-label"><i class="' + payInfo.payment.icon + '"></i> ' + (isEn ? payInfo.payment.nameEn : payInfo.payment.name) + '</div>';
                html += '<div class="device-tags">';
                payInfo.devices.forEach(function (dev) {
                    html += '<span class="device-tag"><i class="' + dev.icon + '"></i> ' + (isEn ? dev.nameEn : dev.name) + '</span>';
                });
                html += '</div>';
                html += '</div>';
            });

            html += '</div>';
            html += '<div class="search-result-cta">';
            html += '<p class="result-note">' + (isEn ? 'Common supported pack. Contact sales to confirm final configuration and pricing.' : '常见可支持方案，最终配置与报价请联系销售确认。') + '</p>';
            html += '<a href="contact.html" class="btn-primary btn-sm">' + (isEn ? 'Contact Sales' : '联系销售获取详情') + ' <i class="fas fa-arrow-right"></i></a>';
            html += '</div>';
            html += '</div>';
        });

        html += '</div>';
        container.innerHTML = html;
        container.style.display = 'block';

        // 保持当前视口位置，不自动滚动以确保模块完整显示
    }

