    var currentLang = localStorage.getItem('lang') || 'zh';

    // ==================== 3. API 接口层 (预留) ====================
    var API = {
        /**
         * 获取所有产品列表
         * 未来替换为: fetch('/api/products')
         */
        getProducts: function () {
            return Promise.resolve(PRODUCT_DATA);
        },

        /**
         * 根据ID获取单个产品
         * 未来替换为: fetch('/api/products/' + id)
         */
        getProductById: function (id) {
            return Promise.resolve(PRODUCT_DATA[id] || null);
        },

        /**
         * 提交报价请求
         * 未来替换为: fetch('/api/quote', { method: 'POST', body: data })
         */
        submitQuote: function (data) {
            console.log('[API] Quote submitted:', data);
            return Promise.resolve({ success: true, message: '已收到您的请求' });
        },

        /**
         * 获取下载资源列表
         * 未来替换为: fetch('/api/downloads/' + productId)
         */
        getDownloads: function (productId) {
            var product = PRODUCT_DATA[productId];
            return Promise.resolve(product ? product.downloads : []);
        },

        /**
         * 获取解决方案列表
         * 未来替换为: fetch('/api/solutions')
         */
        getSolutions: function () {
            return Promise.resolve([]); // TODO: 补充方案数据
        }
    };

    // ==================== 4. i18n 模块 ====================
    function setLanguage(lang) {
        currentLang = lang;
        localStorage.setItem('lang', lang);

        var langSpan = document.getElementById('currentLang');
        if (langSpan) {
            langSpan.innerHTML = lang === 'zh' ? '中文 \uD83C\uDDE8\uD83C\uDDF3' : 'English \uD83C\uDDEC\uD83C\uDDE7';
        }

        document.querySelectorAll('[data-i18n]').forEach(function (el) {
            var key = el.getAttribute('data-i18n');
            if (translations[lang] && translations[lang][key]) {
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.value = translations[lang][key];
                } else {
                    el.innerHTML = translations[lang][key];
                }
            }
        });
    }

    function t(key) {
        return (translations[currentLang] && translations[currentLang][key]) || key;
    }

    function getLocalized(product, field) {
        if (!product) return '';
        if (currentLang === 'en' && product[field + 'En']) return product[field + 'En'];
        return product[field] || '';
    }

    // ==================== 5. 图片配置加载 ====================
    var CONFIG_STORAGE_KEY = 'totem_image_config_v2';

    function showLoading(show) {
        var el = document.getElementById('configLoading');
        if (el) el.style.display = show ? 'flex' : 'none';
    }

    function renderIcons(container, iconsArray) {
        if (!container) return;
        var valid = (iconsArray || []).filter(function (item) {
            return item && item.startsWith('data:image');
        });
        container.style.display = 'grid';
        container.style.alignItems = 'center';
        container.style.justifyItems = 'center';
        if (valid.length === 0) {
            container.style.gridTemplateColumns = '1fr';
            container.innerHTML = '';
            var def = document.createElement('div');
            def.className = 'icon-item';
            def.innerHTML = '<i class="fas fa-microchip" style="font-size:2.5rem;color:var(--primary);"></i>';
            container.appendChild(def);
            return;
        }
        container.style.gridTemplateColumns = 'repeat(' + valid.length + ', 1fr)';
        container.innerHTML = '';
        valid.forEach(function (b64) {
            var div = document.createElement('div');
            div.className = 'icon-item';
            var img = document.createElement('img');
            img.src = b64;
            img.alt = 'payment icon';
            img.loading = 'lazy';
            div.appendChild(img);
            container.appendChild(div);
        });
    }

    function applyLogo(b64) {
        var logo = document.getElementById('totemLogo');
        if (!logo) return;
        if (b64 && b64.startsWith('data:image')) {
            logo.innerHTML = '';
            var img = document.createElement('img');
            img.src = b64;
            img.alt = 'Totem Logo';
            img.style.height = '42px';
            img.style.width = 'auto';
            logo.appendChild(img);
            logo.style.background = 'none';
            logo.style.color = 'inherit';
        } else {
            logo.innerHTML = 'Totem<span>.</span>';
            logo.style.background = 'linear-gradient(135deg, #E55A2C, #B43A12)';
            logo.style.webkitBackgroundClip = 'text';
            logo.style.backgroundClip = 'text';
            logo.style.color = 'transparent';
        }
    }

    function loadConfigAndApply() {
        showLoading(true);
        var local = localStorage.getItem(CONFIG_STORAGE_KEY);
        if (local) {
            try {
                var cfg = JSON.parse(local);
                applyLogo(cfg.logo);
                renderIcons(document.getElementById('readerIconsContainer'), cfg.readerIcons);
                renderIcons(document.getElementById('banknoteIconsContainer'), cfg.banknoteIcons);
                renderIcons(document.getElementById('coinIconsContainer'), cfg.coinIcons);
                showLoading(false);
                return;
            } catch (e) { console.warn(e); }
        }
        fetch('./config.json')
            .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
            .then(function (cfg) {
                applyLogo(cfg.logo);
                renderIcons(document.getElementById('readerIconsContainer'), cfg.readerIcons);
                renderIcons(document.getElementById('banknoteIconsContainer'), cfg.banknoteIcons);
                renderIcons(document.getElementById('coinIconsContainer'), cfg.coinIcons);
                localStorage.setItem(CONFIG_STORAGE_KEY, JSON.stringify(cfg));
                showLoading(false);
            })
            .catch(function () { showLoading(false); });
    }

    // ==================== 6. 移动端菜单 ====================
    function initMobileMenu() {
        var hamburger = document.getElementById('hamburger');
        var navLinks = document.getElementById('navLinks');
        if (!hamburger || !navLinks) return;
        hamburger.addEventListener('click', function () { navLinks.classList.toggle('active'); });
        document.addEventListener('click', function (e) {
            if (window.innerWidth <= 950 && navLinks.classList.contains('active') && !navLinks.contains(e.target) && !hamburger.contains(e.target)) {
                navLinks.classList.remove('active');
            }
        });
        document.querySelectorAll('.nav-links a').forEach(function (link) {
            link.addEventListener('click', function () { if (window.innerWidth <= 950) navLinks.classList.remove('active'); });
        });
    }

    // ==================== 7. Scroll Reveal ====================
    function initScrollReveal() {
        var els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
            els.forEach(function (el) { el.classList.add('visible'); });
            return;
        }
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });
        els.forEach(function (el) { observer.observe(el); });
    }

    // ==================== 8. Section Nav (Sticky) ====================
    function initSectionNav() {
        var nav = document.getElementById('sectionNav');
        if (!nav) return;
        var hero = document.querySelector('.page-hero');
        if (!hero) return;

        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                nav.classList.toggle('visible', !entry.isIntersecting);
            });
        }, { threshold: 0 });
        observer.observe(hero);

        var links = nav.querySelectorAll('.section-nav-link');
        links.forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                var target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    var offset = nav.offsetHeight + 70;
                    var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
                    window.scrollTo({ top: top, behavior: 'smooth' });
                }
            });
        });

        // Highlight active section on scroll
        var sections = [];
        links.forEach(function (link) {
            var target = document.querySelector(link.getAttribute('href'));
            if (target) sections.push({ el: target, link: link });
        });

        window.addEventListener('scroll', function () {
            var scrollPos = window.scrollY + 150;
            var current = null;
            sections.forEach(function (s) {
                if (s.el.offsetTop <= scrollPos) current = s;
            });
            links.forEach(function (l) { l.classList.remove('active'); });
            if (current) current.link.classList.add('active');
        });
    }

    // ==================== 9. 产品详情页渲染 ====================
    function renderProductDetail(productId) {
        var product = PRODUCT_DATA[productId];
        if (!product) return;

        var isEn = currentLang === 'en';

        // Breadcrumb
        var bcCategory = document.getElementById('bcCategory');
        var bcProduct = document.getElementById('bcProduct');
        if (bcCategory) bcCategory.textContent = t('nav_products');
        if (bcProduct) bcProduct.textContent = getLocalized(product, 'category');

        // Hero
        var heroTitle = document.getElementById('detailHeroTitle');
        var heroSubtitle = document.getElementById('detailHeroSubtitle');
        var heroDesc = document.getElementById('detailHeroDesc');
        var heroIcon = document.getElementById('detailHeroIcon');
        if (heroTitle) heroTitle.textContent = getLocalized(product, 'title');
        if (heroSubtitle) heroSubtitle.textContent = getLocalized(product, 'subtitle');
        if (heroDesc) heroDesc.textContent = getLocalized(product, 'description');
        if (heroIcon) heroIcon.className = product.heroIcon + ' hero-icon-fa';

        // Hero Stats
        var statsContainer = document.getElementById('detailHeroStats');
        if (statsContainer && product.stats) {
            statsContainer.innerHTML = product.stats.map(function (s) {
                return '<div class="hero-stat-badge"><span class="value">' + s.value + '</span><span class="label">' + (isEn ? s.labelEn : s.label) + '</span></div>';
            }).join('');
        }

        // Features
        var featuresContainer = document.getElementById('detailFeatures');
        if (featuresContainer && product.features) {
            featuresContainer.innerHTML = product.features.map(function (f, i) {
                return '<div class="feature-card reveal reveal-delay-' + (i % 4 + 1) + '"><div class="feature-icon"><i class="' + f.icon + '"></i></div><h4>' + getLocalized(f, 'title') + '</h4><p>' + getLocalized(f, 'desc') + '</p></div>';
            }).join('');
        }

        // Models
        var modelsContainer = document.getElementById('detailModels');
        if (modelsContainer && product.models) {
            modelsContainer.innerHTML = product.models.map(function (m) {
                var badgeHtml = '';
                var badgeText = isEn ? (m.badgeEn || m.badge) : m.badge;
                if (badgeText) badgeHtml = '<div class="model-badge">' + badgeText + '</div>';
                var specsList = (isEn ? (m.specsEn || m.specs) : m.specs).map(function (s) {
                    return '<li><i class="fas fa-check-circle"></i> ' + s + '</li>';
                }).join('');
                var clickableClass = m.pageFile ? ' clickable' : '';
                var linkBtn = m.pageFile
                    ? '<a href="' + m.pageFile + '" class="btn-outline btn-sm">' + (isEn ? 'View Details' : '查看详情') + ' <i class="fas fa-arrow-right"></i></a>'
                    : '<a href="contact.html" class="btn-outline btn-sm">' + (isEn ? 'Get Quote' : '获取报价') + ' <i class="fas fa-arrow-right"></i></a>';
                return '<a href="' + (m.pageFile || 'contact.html') + '" class="model-card reveal' + (m.badge ? ' recommended' : '') + clickableClass + '" style="text-decoration:none;color:inherit;display:block;">' + badgeHtml + '<div class="model-icon"><i class="' + m.icon + '"></i></div><h4>' + m.name + '</h4><div class="model-subtitle">' + getLocalized(m, 'subtitle') + '</div><ul class="model-specs">' + specsList + '</ul>' + linkBtn + '</a>';
            }).join('');
        }

        // Specs
        var specsContainer = document.getElementById('detailSpecs');
        if (specsContainer && product.specifications) {
            var html = '';
            for (var catName in product.specifications) {
                var cat = product.specifications[catName];
                var catTitle = isEn ? (cat.titleEn || catName) : catName;
                var rows = isEn ? (cat.rowsEn || cat.rows) : cat.rows;
                html += '<div class="spec-category-title">' + catTitle + '</div>';
                html += '<table class="spec-table">';
                rows.forEach(function (row) {
                    html += '<tr><td>' + row[0] + '</td><td>' + row[1] + '</td></tr>';
                });
                html += '</table>';
            }
            specsContainer.innerHTML = html;
        }

        // Scenarios
        var scenariosContainer = document.getElementById('detailScenarios');
        if (scenariosContainer && product.scenarios) {
            scenariosContainer.innerHTML = product.scenarios.map(function (s) {
                return '<div class="scenario-item"><i class="' + s.icon + '"></i><h5>' + getLocalized(s, 'name') + '</h5></div>';
            }).join('');
        }

        // Downloads
        var downloadsContainer = document.getElementById('detailDownloads');
        if (downloadsContainer && product.downloads) {
            downloadsContainer.innerHTML = product.downloads.map(function (d) {
                return '<div class="resource-card"><div class="resource-icon"><i class="' + d.icon + '"></i></div><div class="resource-info"><h5>' + getLocalized(d, 'name') + '</h5><p>' + getLocalized(d, 'desc') + ' · ' + d.size + '</p></div></div>';
            }).join('');
        }

        // Related Products
        var relatedContainer = document.getElementById('detailRelated');
        if (relatedContainer && product.relatedProducts) {
            relatedContainer.innerHTML = product.relatedProducts.map(function (rid) {
                var rp = PRODUCT_DATA[rid];
                if (!rp) return '';
                return '<div class="overview-card"><div class="overview-icon"><i class="' + rp.heroIcon + '"></i></div><h3>' + getLocalized(rp, 'title') + '</h3><p>' + getLocalized(rp, 'subtitle') + '</p><a href="' + rp.pageFile + '" class="link-arrow">' + (isEn ? 'Learn More' : '了解更多') + ' <i class="fas fa-chevron-right"></i></a></div>';
            }).join('');
        }

        // Re-init scroll reveal for dynamically added elements
        setTimeout(initScrollReveal, 100);
    }

    // ==================== 10. 产品总览页渲染 ====================
    function renderProductsOverview() {
        var container = document.getElementById('productsOverviewGrid');
        if (!container) return;
        var isEn = currentLang === 'en';
        var html = '';
        for (var key in PRODUCT_DATA) {
            var p = PRODUCT_DATA[key];
            // Skip sub-products (they'll be listed under their parent)
            if (p.parentCategory) continue;
            var specs = p.stats.map(function (s) {
                return '<span class="spec-tag">' + s.value + '</span>';
            }).join('');
            html += '<div class="overview-card reveal"><div class="overview-icon"><i class="' + p.heroIcon + '"></i></div><h3>' + getLocalized(p, 'title') + '</h3><p>' + getLocalized(p, 'subtitle') + '</p><div class="overview-specs">' + specs + '</div>';
            // Show sub-products as clickable links if this product has models with pageFile
            if (p.models && p.models.length > 0) {
                html += '<div class="sub-product-links" style="margin-bottom:1rem;">';
                p.models.forEach(function (m) {
                    if (m.pageFile) {
                        html += '<a href="' + m.pageFile + '" class="sub-product-link" style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;margin:4px 4px 4px 0;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius-full);font-size:0.8rem;font-weight:600;color:var(--gray-700);text-decoration:none;transition:all 0.2s ease;cursor:pointer;" onmouseover="this.style.borderColor=\'var(--primary)\';this.style.color=\'var(--primary)\';this.style.background=\'var(--primary-light)\'" onmouseout="this.style.borderColor=\'var(--gray-200)\';this.style.color=\'var(--gray-700)\';this.style.background=\'var(--gray-50)\'"><i class="' + m.icon + '" style="font-size:0.75rem;"></i> ' + m.name + '</a>';
                    }
                });
                html += '</div>';
            }
            html += '<a href="' + p.pageFile + '" class="link-arrow">' + (isEn ? 'View Details' : '查看详情') + ' <i class="fas fa-chevron-right"></i></a></div>';
        }
        container.innerHTML = html;
        setTimeout(initScrollReveal, 100);
    }
    // ==================== 12B. 解决方案页渲染 ====================
function renderSolutionsPage() {
    var container = document.getElementById('solutionsGrid');
    if (!container) return;
    var isEn = currentLang === 'en';
    var html = '';
    for (var key in SOLUTION_DATA) {
        var s = SOLUTION_DATA[key];
        var statsHtml = s.stats.map(function (st) {
            return '<span class="spec-tag">' + st.value + '</span>';
        }).join('');
        html += '<div class="overview-card reveal">';
        html += '<div class="overview-icon"><i class="' + s.icon + '"></i></div>';
        html += '<h3>' + getLocalized(s, 'title') + '</h3>';
        html += '<p>' + getLocalized(s, 'subtitle') + '</p>';
        html += '<div class="overview-specs">' + statsHtml + '</div>';
        html += '<a href="' + s.pageFile + '" class="link-arrow">' + (isEn ? 'View Details' : '查看详情') + ' <i class="fas fa-chevron-right"></i></a>';
        html += '</div>';
    }
    container.innerHTML = html;
    setTimeout(initScrollReveal, 100);
}

// ==================== 12C. 技术支持页渲染 ====================
function renderSupportPage() {
    var isEn = currentLang === 'en';

    // Categories
    var catContainer = document.getElementById('supportCategories');
    if (catContainer) {
        catContainer.innerHTML = SUPPORT_DATA.categories.map(function (cat) {
            var itemsHtml = cat.items.map(function (item) {
                return '<div class="resource-card"><div class="resource-icon"><i class="' + cat.icon + '"></i></div><div class="resource-info"><h5>' + getLocalized(item, 'name') + '</h5><p>' + getLocalized(item, 'desc') + ' · ' + item.size + '</p></div></div>';
            }).join('');
            return '<div class="reveal"><h3 style="font-size:1.3rem;margin-bottom:1.2rem;display:flex;align-items:center;gap:10px;"><i class="' + cat.icon + '" style="color:var(--primary);"></i> ' + getLocalized(cat, 'title') + '</h3><div class="resource-grid">' + itemsHtml + '</div></div>';
        }).join('');
    }

    // FAQ
    var faqContainer = document.getElementById('supportFaq');
    if (faqContainer) {
        faqContainer.innerHTML = SUPPORT_DATA.faq.map(function (item, i) {
            var html = '<div class="faq-item reveal" style="border:1px solid var(--gray-200);border-radius:var(--radius-md);margin-bottom:1rem;overflow:hidden;">';
            html += '<div class="faq-question" onclick="this.parentElement.classList.toggle(\'open\')" style="padding:1rem 1.5rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-weight:600;font-size:0.95rem;">';
            html += '<span>' + getLocalized(item, 'q') + '</span>';
            html += '<i class="fas fa-chevron-down" style="transition:transform 0.2s;color:var(--gray-400);"></i>';
            html += '</div>';
            html += '<div class="faq-answer" style="padding:0 1.5rem;max-height:0;overflow:hidden;transition:all 0.3s ease;color:var(--gray-600);font-size:0.9rem;line-height:1.7;">';
            html += '<div style="padding-bottom:1rem;">' + getLocalized(item, 'a') + '</div>';
            html += '</div></div>';
            return html;
        }).join('');
    }

    setTimeout(initScrollReveal, 100);
}

    // ==================== 12D. 开发者页渲染 ====================
    function renderDevelopersPage() {
        var isEn = currentLang === 'en';

        // Quick Start
        var qsContainer = document.getElementById('devQuickStart');
        if (qsContainer) {
            qsContainer.innerHTML = DEVELOPER_DATA.quickStart.map(function (s) {
                return '<div class="feature-card reveal"><div class="feature-icon"><span style="font-size:1.4rem;font-weight:800;color:var(--primary);">' + s.step + '</span></div><h4>' + getLocalized(s, 'title') + '</h4><p>' + getLocalized(s, 'desc') + '</p></div>';
            }).join('');
        }

        // SDK
        var sdkContainer = document.getElementById('devSdk');
        if (sdkContainer) {
            sdkContainer.innerHTML = DEVELOPER_DATA.sdk.map(function (s) {
                return '<div class="resource-card"><div class="resource-icon"><i class="' + s.icon + '"></i></div><div class="resource-info"><h5>' + s.name + ' <span style="font-size:0.72rem;color:var(--gray-400);font-weight:400;">' + s.version + '</span></h5><p>' + getLocalized(s, 'desc') + '</p></div></div>';
            }).join('');
        }

        // Tools
        var toolsContainer = document.getElementById('devTools');
        if (toolsContainer) {
            toolsContainer.innerHTML = DEVELOPER_DATA.tools.map(function (t) {
                return '<div class="resource-card"><div class="resource-icon"><i class="' + t.icon + '"></i></div><div class="resource-info"><h5>' + t.name + ' <span style="font-size:0.72rem;color:var(--gray-400);font-weight:400;">' + t.version + '</span></h5><p>' + getLocalized(t, 'desc') + '</p></div></div>';
            }).join('');
        }

        // Samples
        var samplesContainer = document.getElementById('devSamples');
        if (samplesContainer) {
            samplesContainer.innerHTML = DEVELOPER_DATA.samples.map(function (s) {
                var langColor = { 'C': '#555555', 'Python': '#3776AB', 'Java': '#ED8B00', 'JavaScript': '#F7DF1E' };
                return '<div class="feature-card reveal"><div style="display:flex;align-items:center;gap:10px;margin-bottom:0.8rem;"><span style="background:' + (langColor[s.lang] || 'var(--gray-600)') + ';color:white;padding:3px 10px;border-radius:var(--radius-full);font-size:0.72rem;font-weight:700;">' + s.lang + '</span></div><h4 style="font-size:1rem;">' + getLocalized(s, 'title') + '</h4><p>' + getLocalized(s, 'desc') + '</p><a href="#" class="link-arrow" style="margin-top:0.8rem;font-size:0.85rem;">' + (isEn ? 'View Code' : '查看代码') + ' <i class="fas fa-external-link-alt"></i></a></div>';
            }).join('');
        }

        setTimeout(initScrollReveal, 100);
    }


    // ==================== 11. 页面初始化 ====================
    function init() {
        // Language switch
        var langSwitch = document.getElementById('langSwitch');
        if (langSwitch) {
            langSwitch.addEventListener('click', function () {
                setLanguage(currentLang === 'zh' ? 'en' : 'zh');
                // Re-render dynamic content
                var page = document.body.getAttribute('data-page');
                if (page === 'product-detail') {
                    var pid = document.body.getAttribute('data-product');
                    renderProductDetail(pid);
                } else if (page === 'products-overview') {
                    renderProductsOverview();
                } else if (page === 'home') {
                    initSearchOnHome();
                }
            });
        }

        setLanguage(currentLang);

        // Year
        var yearEl = document.getElementById('currentYear');
        if (yearEl) yearEl.innerText = new Date().getFullYear();

        // Mobile menu
        initMobileMenu();

        // Image config
        loadConfigAndApply();

        // Scroll reveal
        initScrollReveal();

        // Section nav
        initSectionNav();

        // Page-specific rendering
        var page = document.body.getAttribute('data-page');
        if (page === 'product-detail') {
            renderProductDetail(document.body.getAttribute('data-product'));
        } else if (page === 'products-overview') {
            renderProductsOverview();
        }
        // Page-specific rendering
        var page = document.body.getAttribute('data-page');
        if (page === 'product-detail') {
            renderProductDetail(document.body.getAttribute('data-product'));
        } else if (page === 'products-overview') {
            renderProductsOverview();
        } else if (page === 'solutions') {
            renderSolutionsPage();
        } else if (page === 'support') {
            renderSupportPage();
        } else if (page === 'developers') {
            renderDevelopersPage();
        }

        // 首页搜索功能
        initSearchOnHome();

    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // ==================== 12. 公开接口 ====================
    return {
        API: API,
        PRODUCT_DATA: PRODUCT_DATA,
        SOLUTION_DATA: SOLUTION_DATA,
        INDUSTRY_DATA: INDUSTRY_DATA,
        SUPPORT_DATA: SUPPORT_DATA,
        DEVELOPER_DATA: DEVELOPER_DATA,
        setLanguage: setLanguage,
        t: t,
        getLocalized: getLocalized,
        getCurrentLang: function () { return currentLang; },
        renderProductDetail: renderProductDetail,
        renderProductsOverview: renderProductsOverview,
        renderSolutionsPage: renderSolutionsPage,
        renderSupportPage: renderSupportPage,
        renderDevelopersPage: renderDevelopersPage
    };


})();
